{
  "key": "graduate_school",
  "decision_types": [
    "graduate_school",
    "education_career"
  ],
  "summary": "Graduate school vs direct work break-even model.",
  "required_variables": [
    "study_years",
    "annual_tuition_living_cost",
    "direct_work_salary",
    "post_grad_expected_salary"
  ],
  "outputs": [
    "derived_values",
    "proof_state",
    "recommendation",
    "sensitivity",
    "guidance"
  ],
  "verifier": "python",
  "entry_point": "domain.py",
  "questions_path": "questions.md",
  "priors": {
    "target_payback_years_low_risk": 3.0,
    "target_payback_years_medium_risk": 5.0,
    "target_payback_years_high_risk": 7.0
  },
  "model": {
    "intermediates": {
      "cash_cost": {
        "primitive": "product",
        "operands": ["study_years", "annual_tuition_living_cost"]
      },
      "opportunity_cost": {
        "primitive": "product",
        "operands": ["study_years", "direct_work_salary"]
      },
      "total_opportunity_cost": {
        "primitive": "sum",
        "operands": ["cash_cost", "opportunity_cost"]
      },
      "annual_salary_premium": {
        "primitive": "difference",
        "operands": ["post_grad_expected_salary", "direct_work_salary"]
      },
      "payback_years": {
        "primitive": "ratio",
        "numerator": "total_opportunity_cost",
        "denominator": "annual_salary_premium",
        "require_positive_denominator": true
      },
      "funding_gap": {
        "primitive": "positive_difference",
        "operands": ["cash_cost", "savings"]
      },
      "target_payback_years": {
        "primitive": "lookup",
        "key": "risk_tolerance",
        "table": {
          "low": "target_payback_years_low_risk",
          "medium": "target_payback_years_medium_risk",
          "high": "target_payback_years_high_risk"
        }
      },
      "break_even_salary_premium": {
        "primitive": "ratio",
        "numerator": "total_opportunity_cost",
        "denominator": "target_payback_years"
      },
      "break_even_post_grad_salary": {
        "primitive": "sum",
        "operands": ["direct_work_salary", "break_even_salary_premium"]
      }
    }
  },
  "constraints": [
    {
      "id": "G1",
      "claim": "salary_premium_positive",
      "kind": "threshold",
      "value": "annual_salary_premium",
      "op": "gt",
      "limit": 0,
      "severity_on_fail": "hard",
      "dependencies": ["direct_work_salary", "post_grad_expected_salary"],
      "open_reason": "salary premium cannot be computed without current and post-grad salary",
      "reason_closed": "annual salary premium is ${value:.0f}",
      "reason_failed": "annual salary premium is ${value:.0f}"
    },
    {
      "id": "G2",
      "claim": "payback_within_risk_window",
      "kind": "threshold",
      "value": "payback_years",
      "op": "lte",
      "limit": "target_payback_years",
      "severity_on_fail": "warning",
      "decisive": true,
      "dependencies": [
        "study_years",
        "annual_tuition_living_cost",
        "direct_work_salary",
        "post_grad_expected_salary",
        "risk_tolerance"
      ],
      "open_reason": "payback window cannot be checked without payback years and risk tolerance",
      "reason_closed": "payback is {value:.1f} years, inside the {limit:.1f}-year risk window",
      "reason_failed": "payback is {value:.1f} years, above the {limit:.1f}-year risk window"
    },
    {
      "id": "G3",
      "claim": "funding_path_clear",
      "kind": "cases",
      "cases": [
        {
          "when": {"value_unknown": "funding_gap"},
          "status": "open",
          "severity": "warning",
          "reason": "funding gap cannot be computed without tuition/living cost and savings",
          "dependencies": ["annual_tuition_living_cost", "study_years", "savings", "loan_required"]
        },
        {
          "when": {"value_lte": {"name": "funding_gap", "limit": 0}},
          "status": "closed",
          "severity": "soft",
          "reason": "available savings cover the direct cash cost",
          "dependencies": ["annual_tuition_living_cost", "study_years", "savings"]
        },
        {
          "when": {
            "all": [
              {"bool_true": "loan_required"},
              {"text_equals": {"name": "risk_tolerance", "value": "low"}}
            ]
          },
          "status": "failed",
          "severity": "hard",
          "reason": "requires about ${funding_gap:.0f} of debt while risk tolerance is low",
          "dependencies": ["annual_tuition_living_cost", "study_years", "savings", "loan_required", "risk_tolerance"]
        },
        {
          "when": {"bool_true": "loan_required"},
          "status": "assumption",
          "severity": "warning",
          "reason": "requires about ${funding_gap:.0f} of debt financing",
          "dependencies": ["annual_tuition_living_cost", "study_years", "savings", "loan_required"]
        },
        {
          "when": {},
          "status": "open",
          "severity": "warning",
          "reason": "about ${funding_gap:.0f} of funding gap remains unexplained",
          "dependencies": ["annual_tuition_living_cost", "study_years", "savings", "loan_required"]
        }
      ]
    }
  ],
  "recommendation": {
    "target_claim": "graduate_school_better_than_direct_work",
    "evidence_variables": [
      "study_years",
      "annual_tuition_living_cost",
      "direct_work_salary",
      "post_grad_expected_salary",
      "savings"
    ],
    "open_blocks_conclusion": ["salary_premium_positive", "payback_within_risk_window"],
    "key_dependencies": [
      "study_years",
      "annual_tuition_living_cost",
      "direct_work_salary",
      "post_grad_expected_salary",
      "risk_tolerance"
    ]
  },
  "derived_values": {
    "cash_cost": "cash_cost",
    "opportunity_cost": "opportunity_cost",
    "total_opportunity_cost": "total_opportunity_cost",
    "annual_salary_premium": "annual_salary_premium",
    "payback_years_after_graduation": "payback_years",
    "funding_gap": "funding_gap"
  },
  "sensitivity": {
    "current": {
      "target_payback_years": "target_payback_years",
      "current_payback_years": "payback_years",
      "current_salary_premium": "annual_salary_premium",
      "funding_gap": "funding_gap"
    },
    "flip_conditions": {
      "break_even_salary_premium_for_risk_window": "break_even_salary_premium",
      "break_even_post_grad_salary_for_risk_window": "break_even_post_grad_salary",
      "required_savings_without_loan": "cash_cost"
    },
    "unknown_variables": [
      "study_years",
      "annual_tuition_living_cost",
      "direct_work_salary",
      "post_grad_expected_salary",
      "savings",
      "risk_tolerance"
    ]
  },
  "guidance_config": {
    "mode": "goal_cases",
    "cases": [
      {
        "when": {
          "goal_status": {
            "claim": "funding_path_clear",
            "statuses": [
              "failed"
            ]
          }
        },
        "summary": "Tilt against graduate school on the current numbers. This is mainly a funding-path problem, not a fine-tuning problem.",
        "focus_template": "You still need about {funding_gap} of funding, and debt conflicts with your current risk stance.",
        "focus_placeholders": {
          "funding_gap": {
            "source": "current",
            "key": "funding_gap",
            "format": "currency"
          }
        },
        "deprioritize": "Do not spend more time shaving small tuition or lifestyle estimates until funding path and salary upside move.",
        "next_step": "Resolve the funding path before debating softer benefits.",
        "next_step_when_numeric": {
          "template": "First check whether you can close the funding gap without debt. After that, verify whether post-grad salary can credibly reach about {break_even_post_grad_salary_for_risk_window}.",
          "placeholders": {
            "break_even_post_grad_salary_for_risk_window": {
              "source": "flip",
              "key": "break_even_post_grad_salary_for_risk_window",
              "format": "currency",
              "suffix": "/year"
            }
          }
        }
      },
      {
        "when": {
          "goal_status": {
            "claim": "payback_within_risk_window",
            "statuses": [
              "failed"
            ]
          }
        },
        "summary": "Tilt against graduate school. The decision is mostly hanging on salary upside, not on smaller spreadsheet adjustments.",
        "focus": "The main issue is salary upside, not minor cost noise.",
        "focus_when_numeric": {
          "template": "You are modeling about {current_payback_years} years to break even; to fit your {target_payback_years}-year risk window, post-grad salary would need to reach about {break_even_post_grad_salary_for_risk_window}.",
          "placeholders": {
            "current_payback_years": {
              "source": "current",
              "key": "current_payback_years",
              "format": "float2"
            },
            "target_payback_years": {
              "source": "current",
              "key": "target_payback_years",
              "format": "float2"
            },
            "break_even_post_grad_salary_for_risk_window": {
              "source": "flip",
              "key": "break_even_post_grad_salary_for_risk_window",
              "format": "currency",
              "suffix": "/year"
            }
          }
        },
        "deprioritize": "Do not spend more time fine-tuning small tuition or living-cost deltas until salary upside is clearer.",
        "next_step": "Get a more defensible post-grad salary range before debating softer benefits."
      },
      {
        "when": {
          "goal_status": {
            "claim": "salary_premium_positive",
            "statuses": [
              "failed"
            ]
          }
        },
        "summary": "Do not recommend graduate school on the current salary inputs.",
        "focus_from_goal_reason": "salary_premium_positive",
        "focus": "Post-grad salary does not currently exceed direct-work salary.",
        "deprioritize": "Do not spend more time on secondary assumptions until the salary premium itself is believable.",
        "next_step": "Validate post-grad salary upside before changing anything else."
      }
    ],
    "default": {
      "summary": "The conclusion is conditional; the next useful step is to verify the few numbers that truly change payback, not to debate every variable.",
      "focus": "Salary upside and funding path remain the dominant levers in this decision.",
      "deprioritize": "Do not spread effort evenly across every estimate; start with the salary range and funding path.",
      "next_step": "Validate the post-grad salary range and the funding path before changing smaller assumptions."
    }
  },
  "next_questions_config": {
    "mode": "rules",
    "rules": [
      {
        "question_id": "graduate_school.funding_path",
        "when": {
          "goal_status": {
            "claim": "funding_path_clear",
            "statuses": [
              "failed",
              "open",
              "assumption"
            ]
          }
        },
        "question": "What funding is actually secured already, and how much of the remaining cash cost would require debt?",
        "why_template": "`funding_path_clear` is unresolved, and the current model still has about {gap_text} unaccounted for.",
        "why_placeholders": {
          "gap_text": {
            "source": "current",
            "key": "funding_gap",
            "format": "currency",
            "fallback": "the current cash gap"
          }
        },
        "expected_variable_updates": [
          "savings",
          "loan_required"
        ],
        "possible_conclusion_impact": "Could move the case from do_not_recommend to conditional or confirm that debt risk is the blocker.",
        "priority": 100
      },
      {
        "question_id": "graduate_school.post_grad_salary",
        "when": {
          "any": [
            {
              "goal_status": {
                "claim": "salary_premium_positive",
                "statuses": [
                  "failed",
                  "open"
                ]
              }
            },
            {
              "goal_status": {
                "claim": "payback_within_risk_window",
                "statuses": [
                  "failed",
                  "open"
                ]
              }
            }
          ]
        },
        "question": "What realistic post-grad salary range do graduates from your actual target programs achieve?",
        "why_template": "Salary upside is the dominant lever here, and the current break-even point is about {target_text}.",
        "why_placeholders": {
          "target_text": {
            "source": "flip",
            "key": "break_even_post_grad_salary_for_risk_window",
            "format": "currency",
            "suffix": "/year",
            "fallback": "the salary needed to clear your target risk window"
          }
        },
        "expected_variable_updates": [
          "post_grad_expected_salary"
        ],
        "possible_conclusion_impact": "Could flip the recommendation if credible salary upside clears the risk-window threshold.",
        "priority": 95
      },
      {
        "question_id": "graduate_school.risk_tolerance",
        "when": {
          "any": [
            {
              "variable_unknown": "risk_tolerance"
            },
            {
              "goal_status": {
                "claim": "payback_within_risk_window",
                "statuses": [
                  "open"
                ]
              }
            }
          ]
        },
        "question": "What is the longest payback window you would still consider acceptable for this degree?",
        "why_this_question": "The payback goal cannot fully resolve until the risk window is explicit.",
        "expected_variable_updates": [
          "risk_tolerance"
        ],
        "possible_conclusion_impact": "Could change the break-even salary target and make the same economics look acceptable or unacceptable.",
        "priority": 80
      },
      {
        "question_id": "graduate_school.tuition",
        "when": {
          "low_evidence_variable": "annual_tuition_living_cost"
        },
        "question": "What is the best tuition-plus-living-cost estimate you can defend for the years you would be in school?",
        "why_this_question": "Total opportunity cost depends directly on this input, and the current estimate still looks weak.",
        "expected_variable_updates": [
          "annual_tuition_living_cost",
          "study_years"
        ],
        "possible_conclusion_impact": "Could move both the funding gap and the payback period.",
        "priority": 70
      },
      {
        "question_id": "graduate_school.direct_salary",
        "when": {
          "low_evidence_variable": "direct_work_salary"
        },
        "question": "What direct-work salary should the no-school path realistically use right now?",
        "why_this_question": "The baseline salary anchors both salary premium and opportunity cost.",
        "expected_variable_updates": [
          "direct_work_salary"
        ],
        "possible_conclusion_impact": "Could tighten or widen the gap graduate school has to overcome.",
        "priority": 65
      }
    ]
  },
  "derived_value_dependencies": {
    "cash_cost": [
      "study_years",
      "annual_tuition_living_cost"
    ],
    "opportunity_cost": [
      "study_years",
      "direct_work_salary"
    ],
    "total_opportunity_cost": [
      "study_years",
      "annual_tuition_living_cost",
      "direct_work_salary"
    ],
    "annual_salary_premium": [
      "direct_work_salary",
      "post_grad_expected_salary"
    ],
    "payback_years_after_graduation": [
      "study_years",
      "annual_tuition_living_cost",
      "direct_work_salary",
      "post_grad_expected_salary"
    ],
    "funding_gap": [
      "study_years",
      "annual_tuition_living_cost",
      "savings"
    ]
  }
}