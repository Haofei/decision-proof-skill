{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-proof.local/schemas/run_artifact.schema.json",
  "title": "Decision Run Artifact",
  "type": "object",
  "required": [
    "run_id",
    "decision_id",
    "domain",
    "created_at",
    "input_ir_hash",
    "input_ir",
    "derived_values",
    "proof_state",
    "recommendation",
    "derived_value_dependencies",
    "sensitivity",
    "verifier_result",
    "guidance",
    "global_verifier_result"
  ],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "decision_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "input_ir_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_ir": {"type": "object"},
    "derived_values": {"type": "object"},
    "proof_state": {
      "type": "object",
      "required": ["target_claim", "goals"],
      "properties": {
        "target_claim": {"type": "string", "minLength": 1},
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "claim", "status", "severity", "reason", "dependencies"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "claim": {"type": "string", "minLength": 1},
              "status": {"type": "string", "enum": ["closed", "open", "failed", "assumption"]},
              "severity": {"type": "string", "enum": ["hard", "warning", "soft"]},
              "reason": {"type": "string", "minLength": 1},
              "dependencies": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "recommendation": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["recommend", "lean_yes", "baseline", "lean_no", "insufficient_evidence", "do_not_recommend"]
        },
        "summary": {"type": "string"},
        "best_option": {"type": ["string", "null"]},
        "evidence_quality": {"type": "string"},
        "key_dependencies": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "derived_value_dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "sensitivity": {
      "type": "object",
      "required": ["current", "flip_conditions"],
      "properties": {
        "current": {"type": "object"},
        "flip_conditions": {"type": "object"}
      },
      "additionalProperties": true
    },
    "verifier_result": {
      "type": "object",
      "required": ["ok", "proof_checked"],
      "properties": {
        "ok": {"type": "boolean"},
        "proof_checked": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "comparison": {
      "type": "object",
      "required": ["options", "ranking"],
      "properties": {
        "options": {
          "type": "array",
          "items": {"type": "object"}
        },
        "ranking": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": true
    },
    "guidance": {
      "type": "object",
      "required": ["summary", "focus", "deprioritize", "next_step"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "focus": {"type": "string", "minLength": 1},
        "deprioritize": {"type": "string", "minLength": 1},
        "next_step": {"type": "string", "minLength": 1},
        "tradeoff": {"type": "string"}
      },
      "additionalProperties": false
    },
    "global_verifier_result": {
      "type": "object",
      "required": ["ok", "passed_invariants", "failed_invariants"],
      "properties": {
        "ok": {"type": "boolean"},
        "passed_invariants": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "failed_invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "message"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "message": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}