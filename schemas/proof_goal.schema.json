{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-proof.local/schemas/proof_goal.schema.json",
  "title": "Decision Proof Goal",
  "type": "object",
  "required": ["id", "claim", "status", "severity", "reason", "dependencies"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["closed", "open", "failed", "assumption"]
    },
    "severity": {
      "type": "string",
      "enum": ["hard", "warning", "soft"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}