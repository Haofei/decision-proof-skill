{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-proof.local/schemas/decision_ir.schema.json",
  "title": "Decision IR",
  "type": "object",
  "required": ["decision", "options", "variables"],
  "properties": {
    "decision": {
      "type": "object",
      "required": ["id", "question", "type"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "question": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1},
        "domain": {"type": "string", "minLength": 1},
        "stakes": {"type": "string"},
        "reversibility": {"type": "string"}
      },
      "additionalProperties": true
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "baseline": {"type": "boolean"},
          "model": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "expression", "status"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "expression": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["known", "unknown", "closed", "open", "failed", "assumption"]}
        },
        "additionalProperties": true
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "unit", "confidence", "source"],
        "properties": {
          "value": {
            "type": ["number", "string", "boolean", "null"]
          },
          "unit": {
            "type": ["string", "null"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["known", "unknown", "assumption"]
          }
        },
        "if": {
          "properties": {
            "value": {"type": "null"}
          },
          "required": ["value"]
        },
        "then": {
          "properties": {
            "status": {"const": "unknown"}
          },
          "required": ["status"]
        },
        "additionalProperties": true
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dependencies": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        },
        "additionalProperties": true
      }
    },
    "proof_state": {
      "type": "object",
      "required": ["target_claim", "goals"],
      "properties": {
        "target_claim": {"type": "string", "minLength": 1},
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "claim", "status", "severity", "reason", "dependencies"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "claim": {"type": "string", "minLength": 1},
              "status": {"type": "string", "enum": ["closed", "open", "failed", "assumption"]},
              "severity": {"type": "string", "enum": ["hard", "warning", "soft"]},
              "reason": {"type": "string", "minLength": 1},
              "dependencies": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "recommendation": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["recommend", "lean_yes", "baseline", "lean_no", "insufficient_evidence", "do_not_recommend"]
        },
        "summary": {"type": "string"},
        "key_dependencies": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}