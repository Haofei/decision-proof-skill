{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-proof.local/schemas/domain_manifest.schema.json",
  "title": "Decision Domain Manifest",
  "type": "object",
  "required": ["key", "decision_types", "required_variables", "outputs", "verifier", "entry_point"],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "decision_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string"
    },
    "required_variables": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["derived_values", "proof_state", "recommendation", "sensitivity", "comparison", "guidance"]
      }
    },
    "verifier": {
      "type": "string",
      "enum": ["none", "lean", "python"]
    },
    "entry_point": {
      "type": "string",
      "minLength": 1
    },
    "questions_path": {
      "type": "string"
    },
    "examples_dir": {
      "type": "string"
    },
    "tests_dir": {
      "type": "string"
    },
    "sensitivity_module": {
      "type": "string"
    },
    "options_module": {
      "type": "string"
    },
    "verifier_module": {
      "type": "string"
    }
  },
  "additionalProperties": true
}